HOST=0.0.0.0
PORT=3000
LOG_LEVEL=info

# GB defaults used when Plex omits X-Plex-Country or X-Plex-Language.
APPLE_COUNTRY=GB
APPLE_LOCALE=en_GB
APPLE_STOREFRONT_ID=143444

# These values mirror Subler at the time this scaffold was created. Apple may
# change the undocumented UTS contract without notice.
UTS_V2_API_VERSION=58
ENABLE_UTS_V3=false
UTS_V3_API_VERSION=82

# Apple-hosted artwork is disabled because usage and caching require a separate
# rights review. See docs/legal-and-operational.md.
ENABLE_APPLE_ARTWORK=false

CACHE_PATH=./data/cache.sqlite
SEARCH_CACHE_TTL_SECONDS=604800
DETAIL_CACHE_TTL_SECONDS=2592000
REQUEST_TIMEOUT_MS=10000
MAX_UPSTREAM_RESPONSE_BYTES=5000000
